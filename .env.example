# Application Settings
APP_NAME="RAG Chatbot API"
APP_ENV=local
DEBUG=true
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# Security Settings
API_KEY=your_secure_api_key_here

# Vector Store / Database Settings
FAISS_INDEX_PATH="data/faiss_index"

# Embedding Model Configuration (LangChain compatible)
# e.g., "openai", "huggingface", "google"
EMBEDDINGS_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-small

# LLM Configuration
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o
TEMPERATURE=0.0

# API Keys (fill these in your local .env file)
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIzaSy...
ANTHROPIC_API_KEY=sk-ant-...
